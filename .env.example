PORT=3000
HOST=0.0.0.0

# Raw URL for the bell repo's tables.json (source of truth for table codes).
TABLES_URL=https://raw.githubusercontent.com/gatherloop/game-master-bell/main/packages/shared/src/tables.json
# On-disk cache used as a fallback when a fetch fails, and to survive restarts.
TABLES_CACHE_PATH=./data/tables-cache.json
# How often to refresh tables data from TABLES_URL, in milliseconds (default: 1 hour).
TABLES_REFRESH_INTERVAL_MS=3600000

# Path to the SQLite file backing the subscriptions store.
SUBSCRIPTIONS_DB_PATH=./data/subscriptions.db

# Shared secret staff enter in the receiver PWA to subscribe/unsubscribe a
# device. Required — POST/DELETE /subscriptions reject everything with 401
# if this is unset. Generate with e.g. `openssl rand -hex 16`.
STAFF_PASSCODE=

# VAPID key pair for Web Push. Generate a pair with `pnpm run vapid:generate`
# and paste both values here; never commit real keys. VAPID_PUBLIC_KEY is
# served publicly at GET /vapid-key. VAPID_PRIVATE_KEY is unused until phase
# A4 wires up the actual push send, but is generated and stored now.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
